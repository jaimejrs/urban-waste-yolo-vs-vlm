# Copie este arquivo para .env e preencha somente se for baixar dados, reconstruir data/unified ou inferir novamente.

# Roboflow API key
ROBOFLOW_API_KEY=your_roboflow_api_key

# Roboflow dataset: garbage-8uzha
ROBOFLOW_WORKSPACE_GARBAGE_8UZHA=project-r1emy
ROBOFLOW_PROJECT_GARBAGE_8UZHA=garbage-8uzha
ROBOFLOW_VERSION_GARBAGE_8UZHA=1
# Classes positivas: black_bag, white_bag (1.838 imagens de referencia)

# Roboflow dataset: garbage-mvzg3
ROBOFLOW_WORKSPACE_GARBAGE_MVZG3=bill-lhxqf
ROBOFLOW_PROJECT_GARBAGE_MVZG3=garbage-mvzg3
ROBOFLOW_VERSION_GARBAGE_MVZG3=1
# Classe positiva: trash bag (865 imagens de referencia)
# Classe negativa: Roadway, sem trash bag

# Negativos Roadway: 10% da quantidade de imagens positivas, no maximo 271
UNIFIED_BACKGROUND_RATIO=0.10
UNIFIED_BACKGROUND_MAX_IMAGES=271

# Roboflow dataset: external Brazilian street test set
ROBOFLOW_WORKSPACE_TESTE=jaime-teixeira
ROBOFLOW_PROJECT_TESTE=urban-waste-brazil
ROBOFLOW_VERSION_TESTE=1

# Run All reiniciavel: etapas concluidas e caches validos sao reutilizados
RUN_ALL_PIPELINE=true
FORCE_DOWNLOAD_DADOS=false
FORCE_REBUILD_DADOS=false
FORCE_TREINO_YOLO=false

# LM Studio 0.4.15 (Build 2); file gemma-4-31B-it-QAT-Q4_0.gguf (GGUF Q4_0)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-4-31b-qat

# YOLO base checkpoint used for fine-tuning
YOLO_PRETRAINED=yolo11m.pt
