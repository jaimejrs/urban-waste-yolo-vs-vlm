# Copie este arquivo para .env e preencha somente se for baixar dados, reconstruir data/unified ou inferir novamente.

# Roboflow API key
ROBOFLOW_API_KEY=your_roboflow_api_key

# Roboflow dataset: garbage-8uzha
ROBOFLOW_WORKSPACE_GARBAGE_8UZHA=project-r1emy
ROBOFLOW_PROJECT_GARBAGE_8UZHA=garbage-8uzha
ROBOFLOW_VERSION_GARBAGE_8UZHA=1

# Roboflow dataset: garbage-mvzg3
ROBOFLOW_WORKSPACE_GARBAGE_MVZG3=bill-lhxqf
ROBOFLOW_PROJECT_GARBAGE_MVZG3=garbage-mvzg3
ROBOFLOW_VERSION_GARBAGE_MVZG3=1

# Roboflow dataset: negative/background images (Sidewalk Segmentation)
ROBOFLOW_WORKSPACE_SIDEWALK=your_workspace
ROBOFLOW_PROJECT_SIDEWALK=your_project
ROBOFLOW_VERSION_SIDEWALK=1

# Roboflow dataset: external Brazilian street test set
ROBOFLOW_WORKSPACE_TESTE=your_workspace
ROBOFLOW_PROJECT_TESTE=your_project
ROBOFLOW_VERSION_TESTE=1

# LM Studio OpenAI-compatible server for Gemma 4 31B-QAT
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=gemma-4-31b-qat

# YOLO base checkpoint used for fine-tuning
YOLO_PRETRAINED=yolo11m.pt

# Optional: cap TACO positive samples to balance training sources.
# If unset, the notebook uses its internal default.
TACO_N_ALVO=1500
